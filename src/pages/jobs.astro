---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteData } from '../lib/data';
---

<BaseLayout title={`${siteData.brand} | Job Postings`}>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Jobs</p>
      <h1>Job postings</h1>
      <p>
        The Baton Rouge SQL Server and Baton Rouge .NET User Groups collect job
        postings from local companies seeking related technology professionals.
      </p>
    </div>
  </section>

  <section class="panel prose-panel">
    <h2>Types of positions listed</h2>
    <p>Postings typically include positions such as:</p>
    <ul>
      <li>Database Administrators (DBA)</li>
      <li>Business Intelligence developers</li>
      <li>SQL Server Reporting Services (SSRS) developers</li>
      <li>ETL / SSIS developers</li>
      <li>Data analysts and data engineers</li>
      <li>.NET developers (web, Windows, mobile)</li>
      <li>Programmer / analysts</li>
    </ul>

    <h2>Submit a job posting</h2>
    <p>
      To have your job posting shared with our group, email us at
      <a href={`mailto:${siteData.contactEmail}?subject=Job Posting`}>{siteData.contactEmail}</a>
      with the position title, company name, a brief description, and a link or
      contact for applicants.
    </p>
    <p>
      Job postings are shared with attendees of both the SQL Server and .NET user
      groups and announced on our <a href={siteData.meetupUrl} target="_blank" rel="noreferrer">Meetup page</a>.
    </p>
  </section>
</BaseLayout>
