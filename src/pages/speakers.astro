---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { siteData, speakers as allSpeakers } from '../lib/data';
const speakers = allSpeakers.filter(s => s.id !== 'seed-speaker-open');
---

<BaseLayout title={`${siteData.brand} | Speakers`}>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Speakers</p>
        <h1>BRSSUG presenters</h1>
        <p>
          BRSSUG features Microsoft MVPs, local experts, and community members presenting on
          SQL Server, Azure, Power BI, .NET, and more. Got a talk idea? We'd love to have you present.
        </p>
        <div class="hero-actions">
          <a class="button" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/call-for-speakers/`}>Submit a talk</a>
        </div>
      </div>
    </div>
  </section>

  <section class="panel stack">
    <SectionHeading
      eyebrow="Profiles"
      title="Speakers"
      text="Speaker details sync from Sessionize. Past and upcoming presenters appear below."
    />
    <div class="cards-grid">
      {speakers.map((speaker) => <SpeakerCard speaker={speaker} />)}
    </div>
  </section>
</BaseLayout>