---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteData } from '../lib/data';
---

<BaseLayout title={`${siteData.brand} | Upcoming Events Schedule`}>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Calendar</p>
      <h1>Upcoming events schedule</h1>
      <p>
        Subscribe to our Google Calendar to get all BRSSUG and Baton Rouge User Group
        events delivered directly to your calendar app.
      </p>
    </div>
  </section>

  <section class="panel prose-panel">
    <h2>Subscribe to the group calendar</h2>
    <p>Add <strong>sqlpassbr@gmail.com</strong> to your Google Calendar contacts, or use one of the links below.</p>

    <h2>Google Calendar embed</h2>
    <p>
      <a href="https://calendar.google.com/calendar/embed?src=sqlpassbr%40gmail.com&ctz=America%2FChicago" target="_blank" rel="noreferrer">
        View calendar in browser →
      </a>
    </p>

    <h2>iCal / subscribe link</h2>
    <p>Use this URL in Apple Calendar, Outlook, or any calendar app that supports iCal subscriptions:</p>
    <p>
      <code>https://calendar.google.com/calendar/ical/sqlpassbr%40gmail.com/public/basic.ics</code>
    </p>

    <h2>Meetup</h2>
    <p>
      Meeting announcements with full details (speaker bio, location confirmation, RSVP) are always
      posted to <a href={siteData.meetupUrl} target="_blank" rel="noreferrer">our Meetup group</a>.
      Join Meetup to get email reminders before each meeting.
    </p>

    <h2>YouTube</h2>
    <p>
      All meetings are streamed live and archived. If you can't make it in person,
      watch on our <a href="https://www.youtube.com/@BRUserGroups" target="_blank" rel="noreferrer">YouTube channel</a>.
    </p>
  </section>
</BaseLayout>
