---
import BaseLayout from '../layouts/BaseLayout.astro';
import MeetingCard from '../components/MeetingCard.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection } from 'astro:content';
import { siteData, speakers } from '../lib/data';
import { formatDate } from '../lib/format';

const allMeetings = await getCollection('meetings');
// Use UTC midnight today so date-only frontmatter values compare correctly
const today = new Date();
const todayUtc = new Date(Date.UTC(today.getUTCFullYear(), today.getUTCMonth(), today.getUTCDate()));

const upcoming = allMeetings
  .filter(m => m.data.date >= todayUtc)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const past = allMeetings
  .filter(m => m.data.date < todayUtc)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const nextMeeting = upcoming[0] ?? null;
const recentPast = past.slice(0, 3);
const featuredSpeakers = speakers.filter(s => s.id !== 'seed-speaker-open').slice(0, 4);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={siteData.title}>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">SQL Server · .NET · Data Platform</p>
        <h1>Baton Rouge's community for data & .NET pros.</h1>
        <p>
          BRSSUG meets monthly at Jones Creek Regional Library for technical talks,
          demos, and community connection. Free and open to everyone.
        </p>
        <div class="hero-actions">
          <a class="button" href={siteData.meetupUrl} target="_blank" rel="noreferrer">Join on Meetup</a>
          <a class="button-secondary" href={`${base}/events/`}>View schedule</a>
        </div>
        <p class="hero-stream-note">
          Can't make it in person? We stream and record every meeting on <a href={siteData.youtubeUrl} target="_blank" rel="noreferrer">YouTube</a>.
        </p>
      </div>

      <aside class="hero-meta">
        <div class="meta-item">
          <span class="meta-label">When</span>
          <span class="meta-value">{siteData.meetingSchedule}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Where</span>
          <span class="meta-value">Jones Creek Regional Library</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Cost</span>
          <span class="meta-value">Free · RSVP encouraged</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Online</span>
          <span class="meta-value">Live streamed on YouTube</span>
        </div>
      </aside>
    </div>
  </section>

  {nextMeeting && (
    <div class="next-meeting-strip">
      <div class="next-meeting-label">Next meeting</div>
      <div class="next-meeting-body">
        <span class="next-meeting-date">{formatDate(nextMeeting.data.date)}</span>
        <span class="next-meeting-divider">·</span>
        <span class="next-meeting-title">{nextMeeting.data.title}</span>
        {nextMeeting.data.speaker !== 'TBD' && (
          <>
            <span class="next-meeting-divider">·</span>
            <span class="next-meeting-speaker">{nextMeeting.data.speaker}</span>
          </>
        )}
      </div>
      <div class="next-meeting-actions">
        <a href={nextMeeting.data.meetupUrl} target="_blank" rel="noreferrer" class="next-meeting-rsvp">
          RSVP on Meetup →
        </a>
      </div>
    </div>
  )}

  {upcoming.length > 0 && (
    <section class="panel stack">
      <SectionHeading
        eyebrow="Upcoming"
        title="Next meetings"
        text="RSVP on Meetup to get reminders and stay up to date on session details."
      />
      <div class="cards-grid">
        {upcoming.map((m) => <MeetingCard meeting={m} />)}
      </div>
    </section>
  )}

  <section class="panel about-panel">
    <SectionHeading
      eyebrow="About"
      title="What is BRSSUG?"
      text=""
    />
    <div class="about-grid">
      <p>
        The Baton Rouge SQL Server &amp; .NET User Group has been connecting local
        technology professionals for years. We're a free, community-run group
        focused on SQL Server, Azure data platform, Power BI, .NET, and related
        Microsoft technologies.
      </p>
      <p>
        Meetings feature presentations from local experts and Microsoft MVPs,
        followed by open discussion and networking. Whether you're a seasoned
        DBA, a .NET developer, or just getting started — you're welcome here.
      </p>
    </div>
    <div class="topic-chips">
      {['SQL Server', 'Azure SQL', 'Power BI', '.NET', 'Azure Data Factory', 'SSIS / SSRS', 'Data Modeling', 'Copilot & AI'].map(t => (
        <span class="chip">{t}</span>
      ))}
    </div>
  </section>

  {recentPast.length > 0 && (
    <section class="panel stack">
      <SectionHeading
        eyebrow="Archive"
        title="Recent meetings"
        text="Missed a session? Catch the recording on YouTube."
      />
      <div class="cards-grid">
        {recentPast.map((m) => <MeetingCard meeting={m} />)}
      </div>
    </section>
  )}

  {featuredSpeakers.length > 0 && (
    <section class="panel stack">
      <SectionHeading
        eyebrow="Speakers"
        title="Past & upcoming speakers"
        text="BRSSUG regularly features Microsoft MVPs and local experts. Interested in presenting? Reach out on Meetup."
      />
      <div class="cards-grid">
        {featuredSpeakers.map((speaker) => <SpeakerCard speaker={speaker} />)}
      </div>
    </section>
  )}

  <section class="panel day-of-data-panel">
    <div class="day-of-data-inner">
      <div>
        <p class="eyebrow">Annual Event</p>
        <h2>Day of Data Baton Rouge</h2>
        <p>Our annual full-day data conference — free sessions, great speakers, and the Baton Rouge data community all in one place.</p>
      </div>
      <a class="button" href="https://www.dayofdatabr.org/" target="_blank" rel="noreferrer">Learn more →</a>
    </div>
  </section>

  <section class="panel sponsorship-cta-panel">
    <div class="sponsorship-cta-inner">
      <div>
        <p class="eyebrow">Get Involved</p>
        <h2>Sponsor a meeting</h2>
        <p>Connect with 50+ SQL Server, .NET, and data platform professionals for $150–$250. Pizza optional, connections guaranteed.</p>
      </div>
      <a class="button-secondary" href={`${base}/sponsorship/`}>Sponsorship info →</a>
    </div>
  </section>
</BaseLayout>
