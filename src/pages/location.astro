---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteData } from '../lib/data';
---

<BaseLayout title={`${siteData.brand} | Location`}>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Getting here</p>
      <h1>Location information</h1>
      <p>
        Check the meeting announcement each month to confirm the location —
        we occasionally use our alternate venue.
      </p>
    </div>
  </section>

  <section class="panel stack">
    <div class="location-cards">

      <div class="location-venue-card location-venue-card--primary">
        <p class="card-kicker">Primary location</p>
        <h3>East Baton Rouge Parish Library — Jones Creek</h3>
        <address>
          6222 Jones Creek Road<br />
          Baton Rouge, LA 70817
        </address>
        <a class="card-link" href="https://maps.google.com/?q=6222+Jones+Creek+Road+Baton+Rouge+LA+70817" target="_blank" rel="noreferrer">
          Get directions →
        </a>
      </div>

      <div class="location-venue-card">
        <p class="card-kicker">Alternate location</p>
        <h3>Alliance Safety Council</h3>
        <address>
          10099 Reiger Rd<br />
          Baton Rouge, LA 70809
        </address>
        <p class="card-meta">
          Turn onto North Reiger Rd between the McDonald's and Racetrack on Siegen Lane.
          Located in the building next door to Office Depot. Parking is directly in front.
          Entrance is the double glass doors in the front under the awning — signs will
          point you to where the meeting takes place.
        </p>
        <a class="card-link" href="https://maps.google.com/?q=10099+Reiger+Rd+Baton+Rouge+LA+70809" target="_blank" rel="noreferrer">
          Get directions →
        </a>
      </div>

    </div>
  </section>

  <section class="panel prose-panel">
    <h2>Meeting schedule</h2>
    <p>
      We meet every <strong>second Wednesday of the month at 6:00 PM</strong>.
      Check the <a href={siteData.meetupUrl} target="_blank" rel="noreferrer">Meetup event page</a>
      for the confirmed location each month.
    </p>
    <h2>Questions?</h2>
    <p>
      Call <a href="tel:2257559325">225-755-9325</a> for day-of questions or concerns,
      or email us at <a href={`mailto:${siteData.contactEmail}`}>{siteData.contactEmail}</a>.
    </p>
  </section>
</BaseLayout>
